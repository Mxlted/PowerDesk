<UserControl x:Class="PowerDesk.Modules.FileLockFinder.Views.FileLockFinderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="32,24" AllowDrop="True" DragOver="Root_DragOver" Drop="Root_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Style="{StaticResource TextDisplay}" Text="FileLockFinder"/>
                <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                           Text="Find processes that are holding file or folder handles."/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Relaunch as administrator" Command="{Binding RelaunchAsAdminCommand}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource InverseBoolToVis}}"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                <Button Grid.Row="0" Grid.Column="1" Content="File" Margin="8,0,0,0" Command="{Binding SelectFileCommand}"/>
                <Button Grid.Row="0" Grid.Column="2" Content="Folder" Margin="8,0,0,0" Command="{Binding SelectFolderCommand}"/>
                <Button Grid.Row="0" Grid.Column="3" Content="Scan" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Command="{Binding ScanCommand}"/>
                <TextBlock Grid.Row="1" Grid.ColumnSpan="4" Text="{Binding ScanScopeLabel}"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Processes}" SelectedItem="{Binding SelectedProcess}" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Process" Binding="{Binding DisplayName}" Width="*"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding ProcessPath}" Width="300"/>
                        <DataGridTextColumn Header="Restartable" Binding="{Binding RestartableLabel}" Width="110"/>
                        <DataGridTextColumn Header="Started" Binding="{Binding StartTimeLabel}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Margin="16,0,0,0">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding SelectedProcess, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                        <TextBlock Text="No process selected" Style="{StaticResource TextSubtitle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SelectedProcess, Converter={StaticResource NullToVis}}"
                                DataContext="{Binding SelectedProcess}">
                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource TextSubtitle}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ProcessId, StringFormat=PID {0}}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                        <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,14"/>
                        <TextBlock Text="Path" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding ProcessPath}" FontFamily="Consolas" TextWrapping="Wrap"/>
                        <TextBlock Text="Window" Style="{StaticResource TextCaption}" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding MainWindowTitle}" TextWrapping="Wrap"/>
                        <TextBlock Text="Restartable" Style="{StaticResource TextCaption}" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding RestartableLabel}"/>
                        <UniformGrid Columns="2" Margin="0,16,0,0">
                            <Button Content="Copy PID" Margin="0,0,4,0"
                                    Command="{Binding DataContext.CopyProcessIdCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Open location" Margin="4,0,0,0"
                                    Command="{Binding DataContext.OpenProcessLocationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </UniformGrid>
                        <Button Content="Stop process" Style="{StaticResource DangerButton}" Margin="0,10,0,0"
                                Command="{Binding DataContext.StopProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
