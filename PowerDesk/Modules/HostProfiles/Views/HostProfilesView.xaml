<UserControl x:Class="PowerDesk.Modules.HostProfiles.Views.HostProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Style="{StaticResource TextDisplay}" Text="HostProfiles"/>
                <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                           Text="Save, edit, and apply local Windows hosts file profiles."/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Copy path" Command="{Binding CopyHostsPathCommand}"/>
                <Button Content="Relaunch as administrator" Margin="8,0,0,0"
                        Command="{Binding RelaunchAsAdminCommand}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource InverseBoolToVis}}"/>
                <Button Content="Reload hosts" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCurrentHostsCommand}"/>
            </StackPanel>
        </DockPanel>

        <WrapPanel Grid.Row="1" Margin="0,16,0,16">
            <Border Style="{StaticResource Card}" Width="180" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Profiles" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding ProfileCount}" Style="{StaticResource TextTitle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Width="420" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Hosts file" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding HostsPath}" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Width="220" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Last loaded" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding LastLoaded, StringFormat={}{0:HH:mm:ss}}" Style="{StaticResource TextTitle}" FontSize="16"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Profiles" Style="{StaticResource TextSubtitle}"/>
                        <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
                        <UniformGrid Columns="2" Margin="0,8,0,12">
                            <Button Content="Blank" Margin="0,0,4,0" Command="{Binding AddBlankProfileCommand}"/>
                            <Button Content="From current" Margin="4,0,0,0" Command="{Binding SaveCurrentAsProfileCommand}"/>
                        </UniformGrid>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <Button Content="Delete" Style="{StaticResource DangerButton}" Command="{Binding DeleteSelectedProfileCommand}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding UpdatedLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <TabControl Grid.Column="1" Margin="16,0,0,0">
                <TabItem Header="Profile">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                            <TextBlock Text="No profile selected" Style="{StaticResource TextSubtitle}" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Grid.RowSpan="3" Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}}"
                              DataContext="{Binding SelectedProfile}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold"/>
                            <TextBox Grid.Row="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas"
                                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                     Margin="0,10,0,0"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="Save" Command="{Binding DataContext.SaveSelectedProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Button Content="Apply" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                                        Command="{Binding DataContext.ApplySelectedProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Current hosts">
                    <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                        <TextBox Text="{Binding CurrentHosts}" IsReadOnly="True"
                                 AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas"
                                 HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
