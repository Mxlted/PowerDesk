<UserControl x:Class="PowerDesk.Modules.MonitorDesk.Views.MonitorDeskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Style="{StaticResource TextDisplay}" Text="MonitorDesk"/>
                <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                           Text="Display bounds, work areas, and monitor layout."/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Display settings" Command="{Binding OpenDisplaySettingsCommand}"/>
                <Button Content="Copy summary" Margin="8,0,0,0" Command="{Binding CopySummaryCommand}"/>
                <Button Content="Refresh" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </DockPanel>

        <WrapPanel Grid.Row="1" Margin="0,16,0,16">
            <Border Style="{StaticResource Card}" Width="180" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Displays" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding MonitorCount}" Style="{StaticResource TextTitle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Width="260" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Virtual desktop" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding VirtualBoundsLabel}" Style="{StaticResource TextTitle}" FontSize="16"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Width="220" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Last refresh" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding LastRefresh, StringFormat={}{0:HH:mm:ss}}" Style="{StaticResource TextTitle}" FontSize="16"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="New layout name" Style="{StaticResource TextCaption}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Saved layouts" Style="{StaticResource TextCaption}"/>

                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewLayoutName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,6,0,0"/>
                <Button Grid.Row="1" Grid.Column="1" Content="Save current" Margin="8,6,0,0"
                        Command="{Binding SaveCurrentLayoutCommand}"/>

                <ComboBox Grid.Row="1" Grid.Column="3" Margin="0,6,0,0"
                          ItemsSource="{Binding LayoutPresets}"
                          SelectedItem="{Binding SelectedLayout}"
                          DisplayMemberPath="Name"/>
                <Button Grid.Row="1" Grid.Column="4" Content="Apply" Margin="8,6,0,0"
                        Style="{StaticResource PrimaryButton}" Command="{Binding ApplyLayoutCommand}"/>
                <Button Grid.Row="1" Grid.Column="5" Content="Remove" Margin="8,6,0,0"
                        Command="{Binding RemoveLayoutCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Monitors}" SelectedItem="{Binding SelectedMonitor}" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Monitor" Binding="{Binding DeviceName}" Width="*"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding PrimaryLabel}" Width="110"/>
                        <DataGridTextColumn Header="Bounds" Binding="{Binding BoundsLabel}" Width="180"/>
                        <DataGridTextColumn Header="Work area" Binding="{Binding WorkAreaLabel}" Width="180"/>
                        <DataGridTextColumn Header="Bits" Binding="{Binding BitsPerPixel}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Margin="16,0,0,0">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding SelectedMonitor, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                        <TextBlock Text="No display selected" Style="{StaticResource TextSubtitle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SelectedMonitor, Converter={StaticResource NullToVis}}"
                                DataContext="{Binding SelectedMonitor}">
                        <TextBlock Text="{Binding DeviceName}" Style="{StaticResource TextSubtitle}"/>
                        <TextBlock Text="{Binding PrimaryLabel}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                        <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,14"/>
                        <TextBlock Text="Bounds" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding BoundsLabel}" FontFamily="Consolas" Margin="0,3,0,10"/>
                        <TextBlock Text="Work area" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding WorkAreaLabel}" FontFamily="Consolas" Margin="0,3,0,10"/>
                        <TextBlock Text="Position" Style="{StaticResource TextCaption}"/>
                        <UniformGrid Columns="2" Margin="0,3,0,10">
                            <TextBox Text="{Binding DataContext.EditX, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding DataContext.EditY, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" Margin="4,0,0,0"/>
                        </UniformGrid>
                        <Button Content="Apply position" Margin="0,0,0,10"
                                Command="{Binding DataContext.ApplySelectedMonitorPositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        <TextBlock Text="Pixel format" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding BitsPerPixel, StringFormat={}{0} bits per pixel}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
