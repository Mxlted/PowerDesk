<UserControl x:Class="PowerDesk.Modules.PathEditor.Views.PathEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:PowerDesk.Modules.PathEditor.Models"
             Background="{DynamicResource SurfaceBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Style="{StaticResource TextDisplay}" Text="PathEditor"/>
                <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                           Text="Review and edit User or Machine PATH entries with validation."/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Copy PATH" Command="{Binding CopyRawPathCommand}"/>
                <Button Content="Relaunch as administrator" Margin="8,0,0,0"
                        Command="{Binding RelaunchAsAdminCommand}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource InverseBoolToVis}}"/>
                <Button Content="Reload" Margin="8,0,0,0" Command="{Binding LoadPathCommand}"/>
                <Button Content="Save" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Command="{Binding SavePathCommand}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <WrapPanel Grid.Column="0">
                <Border Style="{StaticResource Card}" Width="160" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Entries" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding EntryCount}" Style="{StaticResource TextTitle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Width="160" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Missing" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding MissingCount}" Style="{StaticResource TextTitle}" Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Width="160" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Duplicates" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding DuplicateCount}" Style="{StaticResource TextTitle}" Foreground="{DynamicResource DangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Scope" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                    <ComboBox Width="140" SelectedValuePath="Tag" SelectedValue="{Binding SelectedScope}">
                        <ComboBoxItem Content="User" Tag="{x:Static m:PathScope.User}"/>
                        <ComboBoxItem Content="Machine" Tag="{x:Static m:PathScope.Machine}"/>
                    </ComboBox>
                    <Button Content="Validate" Margin="12,0,0,0" Command="{Binding ValidateEntriesCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Entry" Binding="{Binding Value}" Width="*"/>
                        <DataGridTextColumn Header="Exists" Binding="{Binding MissingLabel}" Width="90"/>
                        <DataGridTextColumn Header="Duplicate" Binding="{Binding DuplicateLabel}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Margin="16,0,0,0">
                <TabControl>
                    <TabItem Header="Edit">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="Add folder" Style="{StaticResource TextSubtitle}"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewEntry, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                                    <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" Command="{Binding BrowseFolderCommand}"/>
                                </Grid>
                                <Button Content="Add" Margin="0,8,0,0" Command="{Binding AddEntryCommand}"/>

                                <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,18"/>
                                <TextBlock Text="Selected entry" Style="{StaticResource TextSubtitle}"/>
                                <TextBox Text="{Binding SelectedEntry.Value, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"
                                         TextWrapping="Wrap" Margin="0,10,0,0"/>
                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                    <Button Content="Move up" Margin="0,0,4,0" Command="{Binding MoveSelectedUpCommand}"/>
                                    <Button Content="Move down" Margin="4,0,0,0" Command="{Binding MoveSelectedDownCommand}"/>
                                </UniformGrid>
                                <Button Content="Remove selected" Style="{StaticResource DangerButton}" Margin="0,8,0,0"
                                        Command="{Binding RemoveSelectedEntryCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Raw">
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                            <TextBox Text="{Binding RawPath, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </TabItem>

                    <TabItem Header="Backups">
                        <ListBox ItemsSource="{Binding Backups}" Margin="0,12,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock>
                                            <Run Text="{Binding Scope}"/>
                                            <Run Text=" PATH"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TimestampLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
