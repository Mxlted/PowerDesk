<Window x:Class="PowerDesk.Modules.StartupPilot.Views.NoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit note"
        Background="{DynamicResource SurfaceBaseBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="480"
        ResizeMode="NoResize"
        FontFamily="{StaticResource AppFont}"
        FontSize="{StaticResource FontSizeBody}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="HeaderLabel" Style="{StaticResource TextSubtitle}"/>
        <TextBox Grid.Row="1" x:Name="NoteInput" AcceptsReturn="True" TextWrapping="Wrap" Height="120" Margin="0,12,0,0"
                 VerticalScrollBarVisibility="Auto"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="Cancel_Click"/>
            <Button Content="Save" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
