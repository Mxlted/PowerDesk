<UserControl x:Class="PowerDesk.Modules.StartupPilot.Views.StartupPilotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Style="{StaticResource TextDisplay}" Text="StartupPilot"/>
                <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                           Text="Inspect and control everything Windows runs at sign-in."/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="LastScanLabel" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                <Button Content="Rescan" Style="{StaticResource PrimaryButton}" Command="{Binding RescanCommand}"/>
                <Button Content="Relaunch as administrator" Margin="8,0,0,0"
                        Command="{Binding RelaunchAsAdminCommand}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource InverseBoolToVis}}"/>
            </StackPanel>
        </DockPanel>

        <!-- Stat row + filters -->
        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Stat strip -->
            <WrapPanel Grid.Row="0">
                <Border Style="{StaticResource Card}" Margin="0,0,12,12" Width="160" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Total" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding TotalCount}" Style="{StaticResource TextTitle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,12" Width="160" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Enabled" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding EnabledCount}" Style="{StaticResource TextTitle}" Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,12" Width="160" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Disabled" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding DisabledCount}" Style="{StaticResource TextTitle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,12" Width="160" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Orphaned" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding OrphanCount}" Style="{StaticResource TextTitle}" Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,12" Width="160" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="High impact" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding HighImpactCount}" Style="{StaticResource TextTitle}" Foreground="{DynamicResource DangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Filter row -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox Width="240" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Registry"       Margin="14,0,0,0" IsChecked="{Binding FilterRegistry}"/>
                        <CheckBox Content="Startup folder" Margin="14,0,0,0" IsChecked="{Binding FilterStartupFolder}"/>
                        <CheckBox Content="Tasks"          Margin="14,0,0,0" IsChecked="{Binding FilterTaskScheduler}"/>
                        <CheckBox Content="Services"       Margin="14,0,0,0" IsChecked="{Binding FilterService}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox Width="120" SelectedValuePath="Tag" SelectedValue="{Binding StatusFilter}">
                            <ComboBoxItem Content="All status"  Tag="All"/>
                            <ComboBoxItem Content="Enabled"     Tag="Enabled"/>
                            <ComboBoxItem Content="Disabled"    Tag="Disabled"/>
                        </ComboBox>
                        <ComboBox Width="120" Margin="8,0,0,0" SelectedValuePath="Tag" SelectedValue="{Binding ImpactFilter}">
                            <ComboBoxItem Content="All impact" Tag="All"/>
                            <ComboBoxItem Content="High"       Tag="High"/>
                            <ComboBoxItem Content="Medium"     Tag="Medium"/>
                            <ComboBoxItem Content="Low"        Tag="Low"/>
                        </ComboBox>
                        <CheckBox Content="Microsoft" Margin="14,0,0,0" IsChecked="{Binding ShowMicrosoft}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Body: split items / sidebar tabs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="ItemsGrid"
                          ItemsSource="{Binding ItemsView}"
                          SelectedItem="{Binding SelectedItem}"
                          SelectionMode="Extended"
                          IsReadOnly="True">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Toggle"             Click="ToggleMenu_Click"/>
                            <MenuItem Header="Open file location" Click="OpenLocationMenu_Click"/>
                            <MenuItem Header="Copy command line"  Click="CopyMenu_Click"/>
                            <MenuItem Header="Edit note…"         Click="NoteMenu_Click"/>
                            <MenuItem Header="Pin to top"         Click="PinMenu_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Icon}" Width="16" Height="16" Margin="10,0,0,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding Enabled, Mode=OneWay}"
                                              Click="EnableToggle_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name"      Binding="{Binding Name}"        Width="*"/>
                        <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}"   Width="160"/>
                        <DataGridTextColumn Header="Source"    Binding="{Binding SourceLabel}" Width="120"/>
                        <DataGridTextColumn Header="Scope"     Binding="{Binding Scope}"       Width="130"/>
                        <DataGridTemplateColumn Header="Impact" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Pill}">
                                        <TextBlock Text="{Binding ImpactLabel}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource Pill}"
                                                Background="{DynamicResource AccentSoftBrush}"
                                                Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Pinned" Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                                        </Border>
                                        <Border Style="{StaticResource Pill}" Margin="6,0,0,0"
                                                Background="{DynamicResource SurfaceActiveBrush}"
                                                Visibility="{Binding IsOrphaned, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Orphan" Foreground="{DynamicResource WarningBrush}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Side panel -->
            <Border Grid.Column="1" Margin="16,0,0,0">
                <TabControl>
                    <TabItem Header="Details">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0" DataContext="{Binding SelectedItem}">
                                <TextBlock Text="{Binding Name, FallbackValue='Select an item'}" Style="{StaticResource TextSubtitle}"/>
                                <TextBlock Text="{Binding Publisher}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,10"/>
                                <StackPanel>
                                    <TextBlock Text="Command line" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding CommandLine}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Text="Target" Style="{StaticResource TextCaption}" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding TargetPath}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Text="Description" Style="{StaticResource TextCaption}" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Scope" Style="{StaticResource TextCaption}" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding Scope}"/>
                                </StackPanel>
                                <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Open location" Click="OpenLocationMenu_Click"/>
                                    <Button Content="Copy command"  Margin="6,0,0,0" Click="CopyMenu_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="History">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Undo last" Style="{StaticResource PrimaryButton}" Command="{Binding UndoLastCommand}"/>
                                <Button Content="Export CSV" Margin="6,0,0,0" Command="{Binding ExportHistoryCsvCommand}"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" ItemsSource="{Binding HistoryView}" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="When"  Binding="{Binding TimestampDisplay}" Width="150"/>
                                    <DataGridTextColumn Header="Item"  Binding="{Binding ItemName}"        Width="*"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}"          Width="100"/>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}"          Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Bulk">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Style="{StaticResource TextSubtitle}" Text="Bulk actions"/>
                            <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                                       Text="Select rows in the table, then apply."/>
                            <Button Content="Enable selected"  Margin="0,12,0,0" Click="BulkEnable_Click"/>
                            <Button Content="Disable selected" Style="{StaticResource DangerButton}" Margin="0,8,0,0" Click="BulkDisable_Click"/>
                            <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,16"/>
                            <CheckBox Content="Confirm before disable" IsChecked="{Binding ConfirmBeforeDisable}"/>
                            <TextBlock Text="History retention" Style="{StaticResource TextCaption}" Margin="0,12,0,4"/>
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding Retention}">
                                <ComboBoxItem Content="Keep all"      Tag="KeepAll"/>
                                <ComboBoxItem Content="Last 100"      Tag="Last100"/>
                                <ComboBoxItem Content="Last 30 days"  Tag="Last30Days"/>
                            </ComboBox>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
