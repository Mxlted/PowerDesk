<UserControl x:Class="PowerDesk.Modules.WindowSizer.Views.WindowSizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{DynamicResource SurfaceBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Style="{StaticResource TextDisplay}" Text="WindowSizer"/>
                <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                           Text="Resize, snap, and move windows with pixel precision."/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Auto-refresh" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox Width="110" SelectedValuePath="Tag" SelectedValue="{Binding AutoRefreshSeconds}"
                          ToolTip="How often the windows list refreshes automatically.">
                    <ComboBoxItem Content="Off"><ComboBoxItem.Tag><sys:Int32>0</sys:Int32></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="1s"><ComboBoxItem.Tag><sys:Int32>1</sys:Int32></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="2s"><ComboBoxItem.Tag><sys:Int32>2</sys:Int32></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="5s"><ComboBoxItem.Tag><sys:Int32>5</sys:Int32></ComboBoxItem.Tag></ComboBoxItem>
                </ComboBox>
                <Button Content="Refresh" Margin="10,0,0,0" Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </DockPanel>

        <!-- Editor strip -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource TextSubtitle}" Text="Edit window"/>
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="{Binding SelectedWindow.Title, FallbackValue='No window selected'}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Clear selection" Command="{Binding ClearSelectionCommand}"/>
                </Grid>
                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="X" Style="{StaticResource TextCaption}"/>
                        <TextBox Text="{Binding EditX, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Y" Style="{StaticResource TextCaption}"/>
                        <TextBox Text="{Binding EditY, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="Width" Style="{StaticResource TextCaption}"/>
                        <TextBox Text="{Binding EditWidth, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <TextBlock Text="Height" Style="{StaticResource TextCaption}"/>
                        <TextBox Text="{Binding EditHeight, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <Button Grid.Column="4" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom"
                            Content="Apply" Command="{Binding ApplyGeometryCommand}" MinWidth="90"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Body: list (left) + actions (right) in tabs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Windows table -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Windows}" SelectedItem="{Binding SelectedWindow}"
                          IsReadOnly="True" Margin="0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="Auto" MinWidth="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Icon}" Width="16" Height="16"
                                           Margin="10,0,0,0" SnapsToDevicePixels="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Title"   Binding="{Binding Title}"       Width="*" />
                        <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="140"/>
                        <DataGridTextColumn Header="X"       Binding="{Binding X}"           Width="70"/>
                        <DataGridTextColumn Header="Y"       Binding="{Binding Y}"           Width="70"/>
                        <DataGridTextColumn Header="W"       Binding="{Binding Width}"       Width="70"/>
                        <DataGridTextColumn Header="H"       Binding="{Binding Height}"      Width="70"/>
                        <DataGridTextColumn Header="Monitor" Binding="{Binding Monitor}"     Width="140"/>
                        <DataGridTemplateColumn Header="Top" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Pill}"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            Visibility="{Binding IsTopmost, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Pinned" Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Side panel -->
            <Border Grid.Column="1" Margin="16,0,0,0">
                <TabControl>
                    <!-- Actions -->
                    <TabItem Header="Actions">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource TextSubtitle}" Text="Snap"/>
                                <UniformGrid Columns="2" Rows="2" Margin="0,10,0,0">
                                    <Button Content="Left half"   Margin="0,0,6,6" Command="{Binding SnapLeftCommand}"/>
                                    <Button Content="Right half"  Margin="6,0,0,6" Command="{Binding SnapRightCommand}"/>
                                    <Button Content="Top half"    Margin="0,6,6,0" Command="{Binding SnapTopCommand}"/>
                                    <Button Content="Bottom half" Margin="6,6,0,0" Command="{Binding SnapBottomCommand}"/>
                                </UniformGrid>

                                <TextBlock Style="{StaticResource TextSubtitle}" Text="Window" Margin="0,16,0,0"/>
                                <UniformGrid Columns="2" Margin="0,10,0,0">
                                    <Button Content="Center"      Margin="0,0,6,6" Command="{Binding CenterCommand}"/>
                                    <Button Content="Bring front" Margin="6,0,0,6" Command="{Binding BringToFrontCommand}"/>
                                    <Button Content="Maximize"    Margin="0,6,6,0" Command="{Binding MaximizeCommand}"/>
                                    <Button Content="Restore"     Margin="6,6,0,0" Command="{Binding RestoreWindowCommand}"/>
                                </UniformGrid>

                                <TextBlock Style="{StaticResource TextSubtitle}" Text="Topmost" Margin="0,16,0,0"/>
                                <UniformGrid Columns="2" Margin="0,10,0,0">
                                    <Button Content="Pin top"   Margin="0,0,6,0" Command="{Binding PinTopCommand}"/>
                                    <Button Content="Unpin"     Margin="6,0,0,0" Command="{Binding UnpinTopCommand}"/>
                                </UniformGrid>

                                <Button Content="Move to next monitor" Margin="0,12,0,0" Command="{Binding NextMonitorCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Size presets -->
                    <TabItem Header="Sizes">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource TextSubtitle}" Text="Size presets"/>
                                <ListBox ItemsSource="{Binding SizePresets}" SelectedItem="{Binding SelectedSizePreset}" Margin="0,8,0,0" MaxHeight="240">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="Apply" Style="{StaticResource GhostButton}"
                                                        Command="{Binding DataContext.ApplySizePresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Remove" Command="{Binding RemoveSizePresetCommand}" CommandParameter="{Binding SelectedSizePreset}"/>
                                    <Button Content="Reset to defaults" Margin="8,0,0,0" Command="{Binding ResetSizePresetsCommand}"/>
                                </StackPanel>

                                <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,16"/>
                                <TextBlock Text="Add preset" Style="{StaticResource TextCaption}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" Tag="Name"/>
                                    <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding NewPresetWidth, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="2"                  Text="{Binding NewPresetHeight, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Button Content="Add preset" Margin="0,8,0,0" Command="{Binding AddSizePresetCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Layout presets -->
                    <TabItem Header="Layouts">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource TextSubtitle}" Text="Layout presets"/>
                                <ListBox ItemsSource="{Binding LayoutPresets}" SelectedItem="{Binding SelectedLayoutPreset}" Margin="0,8,0,0" MaxHeight="240">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                                                    <Run Text="{Binding Width}"/><Run Text="×"/><Run Text="{Binding Height}"/><Run Text=" @ "/>
                                                    <Run Text="{Binding X}"/><Run Text=","/><Run Text="{Binding Y}"/>
                                                    <Run Text=" • "/><Run Text="{Binding TargetProcessName}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Apply" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ApplyLayoutCommand}" CommandParameter="{Binding SelectedLayoutPreset}"/>
                                    <Button Content="Remove" Margin="8,0,0,0"
                                            Command="{Binding RemoveLayoutCommand}" CommandParameter="{Binding SelectedLayoutPreset}"/>
                                </StackPanel>

                                <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,16"/>
                                <TextBlock Text="Capture selected window" Style="{StaticResource TextCaption}"/>
                                <TextBox Margin="0,6,0,0" Text="{Binding NewLayoutName, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Capture" Margin="0,8,0,0" Command="{Binding CaptureLayoutCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Hotkeys -->
                    <TabItem Header="Hotkeys">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource TextSubtitle}" Text="Hotkeys"/>
                                <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,0"
                                           Text="Press a combination in the recorder, pick an action, then Add."/>

                                <ListBox ItemsSource="{Binding Hotkeys}" SelectedItem="{Binding SelectedHotkey}"
                                         Margin="0,10,0,0" MaxHeight="220">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ActionLabel}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                                </StackPanel>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                          IsChecked="{Binding Enabled, Mode=OneWay}"
                                                          Click="HotkeyEnable_Click"
                                                          VerticalAlignment="Center"
                                                          ToolTip="Enable or disable this hotkey."/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Remove" Command="{Binding RemoveHotkeyCommand}" CommandParameter="{Binding SelectedHotkey}"/>
                                    <Button Content="Re-apply" Margin="8,0,0,0" Click="ReapplyHotkeys_Click"/>
                                </StackPanel>

                                <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,16"/>
                                <TextBlock Text="New hotkey" Style="{StaticResource TextCaption}"/>
                                <TextBox x:Name="HotkeyRecorder" Margin="0,6,0,0"
                                         PreviewKeyDown="HotkeyRecorder_PreviewKeyDown"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         Text="{Binding RecorderText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" x:Name="ActionPicker">
                                        <ComboBoxItem Content="Snap left"   Tag="SnapLeft"/>
                                        <ComboBoxItem Content="Snap right"  Tag="SnapRight"/>
                                        <ComboBoxItem Content="Snap top"    Tag="SnapTop"/>
                                        <ComboBoxItem Content="Snap bottom" Tag="SnapBottom"/>
                                        <ComboBoxItem Content="Center"      Tag="Center"/>
                                        <ComboBoxItem Content="Maximize"    Tag="Maximize"/>
                                    </ComboBox>
                                    <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"
                                            Content="Add" Click="AddHotkey_Click"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
