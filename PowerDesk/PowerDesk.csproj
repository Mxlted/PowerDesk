<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\Brand\PowerDesk.ico</ApplicationIcon>
    <AssemblyName>PowerDesk</AssemblyName>
    <RootNamespace>PowerDesk</RootNamespace>
    <Version>0.3.0</Version>
    <AssemblyVersion>0.3.0.0</AssemblyVersion>
    <FileVersion>0.3.0.0</FileVersion>
    <InformationalVersion>0.3.0</InformationalVersion>
    <Company>PowerDesk</Company>
    <Product>PowerDesk</Product>
    <Description>Modular PC tool hub for Windows.</Description>
    <Copyright>© PowerDesk</Copyright>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <PublishSingleFile>false</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <NoWarn>CA1416;CS8618;NU1701</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <PackageReference Include="TaskScheduler" Version="2.11.0" />
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Assets\Brand\PowerDesk.ico" />
    <None Remove="Assets\Brand\PowerDesk.png" />
    <Resource Include="Assets\Brand\PowerDesk.ico" />
    <Resource Include="Assets\Brand\PowerDesk.png" />
  </ItemGroup>

</Project>
