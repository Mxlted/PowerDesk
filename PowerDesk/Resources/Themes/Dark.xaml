<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <Color x:Key="SurfaceBaseColor">#1B1B1F</Color>
    <Color x:Key="SurfaceColor">#202024</Color>
    <Color x:Key="SurfaceAltColor">#26262B</Color>
    <Color x:Key="SurfaceRaisedColor">#2C2C32</Color>
    <Color x:Key="SurfaceHoverColor">#33333A</Color>
    <Color x:Key="SurfaceActiveColor">#3C3C44</Color>
    <Color x:Key="DividerColor">#2E2E34</Color>
    <Color x:Key="BorderColor">#3A3A42</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#F2F2F5</Color>
    <Color x:Key="TextSecondaryColor">#A8A8B2</Color>
    <Color x:Key="TextDisabledColor">#5C5C65</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#4C8DFF</Color>
    <Color x:Key="AccentHoverColor">#6BA0FF</Color>
    <Color x:Key="AccentPressedColor">#3A78E0</Color>
    <Color x:Key="AccentSoftColor">#2A3A5A</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#3CCB7F</Color>
    <Color x:Key="WarningColor">#E0A93C</Color>
    <Color x:Key="DangerColor">#E5484D</Color>
    <Color x:Key="InfoColor">#4C8DFF</Color>

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBaseColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SurfaceActiveBrush" Color="{StaticResource SurfaceActiveColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}"/>
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

</ResourceDictionary>
