<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SurfaceBaseColor">#F4F5F7</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#F7F8FA</Color>
    <Color x:Key="SurfaceRaisedColor">#FFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#EDEFF3</Color>
    <Color x:Key="SurfaceActiveColor">#E2E5EA</Color>
    <Color x:Key="DividerColor">#E4E6EB</Color>
    <Color x:Key="BorderColor">#D5D8DE</Color>

    <Color x:Key="TextPrimaryColor">#1A1B1F</Color>
    <Color x:Key="TextSecondaryColor">#5C616B</Color>
    <Color x:Key="TextDisabledColor">#A4A8B0</Color>

    <Color x:Key="AccentColor">#2566D8</Color>
    <Color x:Key="AccentHoverColor">#1E55B8</Color>
    <Color x:Key="AccentPressedColor">#194B9F</Color>
    <Color x:Key="AccentSoftColor">#DCE7FB</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>

    <Color x:Key="SuccessColor">#1F8F5A</Color>
    <Color x:Key="WarningColor">#B57D0F</Color>
    <Color x:Key="DangerColor">#C8332B</Color>
    <Color x:Key="InfoColor">#2566D8</Color>

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBaseColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SurfaceActiveBrush" Color="{StaticResource SurfaceActiveColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}"/>
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

</ResourceDictionary>
