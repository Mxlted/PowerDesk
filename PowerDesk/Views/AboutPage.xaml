<UserControl x:Class="PowerDesk.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <ScrollViewer Padding="32,24">
        <StackPanel MaxWidth="780">
            <TextBlock Style="{StaticResource TextDisplay}" Text="About PowerDesk"/>
            <TextBlock Style="{StaticResource TextCaption}" Margin="0,4,0,24"
                       Text="A modular, local-first PC tool hub for power users."/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource TextSubtitle}" Text="Build"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionText"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Runtime"     Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text=".NET 9 / WPF (net9.0-windows)" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Telemetry"   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="None. PowerDesk makes no network calls." Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Accounts"    Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="No sign-in required." Margin="0,6,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource TextSubtitle}" Text="Installed tools"/>
                    <ItemsControl x:Name="ModuleList" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Description}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
